---
import '../styles/index.css';
import Calculator from '../components/Calculator';
import SimulationLimits from '../components/FAQ';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Acheter ou Louer ? Le Comparateur Immobilier France</title>
		<meta name="description" content="Comparez le coût réel d'un achat immobilier face à la location en France. Inclut frais de notaire 2025, taxe foncière, entretien et intérêts." />
	</head>
	<body>
		<main class="container">
			<header style="text-align: center; margin-bottom: 4rem; padding-top: 2rem;">
				<div style="display: inline-flex; align-items: center; justify-content: center; background: rgba(37, 99, 235, 0.1); padding: 0.75rem 1.5rem; border-radius: 2rem; color: var(--primary); font-weight: 600; font-size: 0.875rem; margin-bottom: 1.5rem;">
					Mise à jour : DMTO Avril 2025
				</div>
				<h1 style="font-size: 3.5rem; line-height: 1.1; margin-bottom: 1rem; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
					Acheter ou Louer ?
				</h1>
				<p style="font-size: 1.25rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 1.5rem auto;">
					Une simulation complète et réaliste pour prendre la meilleure décision financière pour votre avenir.
				</p>
				<div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.875rem;">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #f59e0b;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
					<span>Note : Cette simulation comporte des limites importantes.</span>
					<a href="#faq" style="color: var(--primary); text-decoration: none; font-weight: 500; border-bottom: 1px solid transparent; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='transparent'">Limites & Hypothèses</a>
				</div>
			</header>

			<Calculator client:load />

			<SimulationLimits client:load />

			<footer style="margin-top: 6rem; padding: 4rem 0; border-top: 1px solid var(--card-border); text-align: center; color: var(--text-muted); font-size: 0.875rem;">
				<p>© 2026 Comparateur Immobilier. Les calculs sont basés sur des estimations et ne remplacent pas l'avis d'un professionnel.</p>
			</footer>
		</main>
	</body>
</html>
